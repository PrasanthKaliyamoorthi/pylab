   "source": [
    "import numpy as np\n",
    "\n",
    "# Inputs and weights\n",
    "inputs = np.array([1, 2])\n",
    "weights = np.array([0.5, 0.3])\n",
    "\n",
    "# Calculate output\n",
    "output = np.dot(inputs, weights)\n",
    "activated_output = max(0, output)  # ReLU\n",
    "\n",
    "print(f\"Output: {activated_output}\")  # Output: 1.1"
   ]
